{
  "name": "when",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @when/server dev & pnpm --filter @when/web dev & wait",
    "build": "pnpm --filter @when/shared build && pnpm --filter @when/server build && pnpm --filter @when/web build",
    "start": "node projects/server/dist/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}